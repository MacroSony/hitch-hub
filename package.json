{
  "name": "hitch-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hitch: a lightweight chat-native control plane for local coding agents.",
  "scripts": {
    "dev": "node --use-env-proxy --import tsx src/main.ts",
    "smoke:fake": "node --use-env-proxy --import tsx src/main.ts --config examples/config.smoke.yaml --fake-message \"!status\"",
    "smoke:media-cache": "node --use-env-proxy --import tsx src/smoke/media-cache.ts --config examples/config.smoke.yaml",
    "smoke:pi-rpc": "node --use-env-proxy --import tsx src/smoke/pi-rpc-state.ts --config examples/config.smoke.yaml",
    "smoke:pi-approval": "node --use-env-proxy --import tsx src/smoke/pi-approval.ts",
    "smoke:telegram-getme": "node --use-env-proxy --import tsx src/smoke/telegram-health.ts --config examples/config.example.yaml --mode getMe",
    "smoke:telegram-updates": "node --use-env-proxy --import tsx src/smoke/telegram-health.ts --config examples/config.example.yaml --mode getUpdates",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
